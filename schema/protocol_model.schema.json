{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/protocol_model.schema.json",
  "title": "Protocol Reverse Engineering Model",
  "type": "object",
  "required": ["protocol_name", "version", "families"],
  "additionalProperties": false,
  "properties": {
    "protocol_name": {"type": "string"},
    "version": {"type": "string"},
    "metadata": {"type": "object"},
    "families": {
      "type": "array",
      "items": {"$ref": "#/$defs/family"}
    },
    "relations": {
      "type": "array",
      "items": {"$ref": "#/$defs/family_relation"}
    }
  },
  "$defs": {
    "segment": {
      "type": "object",
      "required": ["start", "end", "kind", "confidence"],
      "additionalProperties": false,
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "kind": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "evidence": {"type": "object"}
      }
    },
    "field_hypothesis": {
      "type": "object",
      "required": ["family_id", "start", "length", "field_type", "confidence"],
      "additionalProperties": false,
      "properties": {
        "family_id": {"type": "string"},
        "start": {"type": "integer", "minimum": 0},
        "length": {"type": "integer", "minimum": 1},
        "field_type": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "endian": {"type": ["string", "null"]},
        "layer": {"type": ["string", "null"], "enum": ["transport", "application", "unknown", null], "description": "A6: Protocol layer attribution"},
        "evidence": {"type": "object"},
        "attributes": {"type": "object"}
      }
    },
    "family_semantic_summary": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "family_id": {"type": "string"},
        "role": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "field_labels": {
          "type": "array",
          "items": {"type": "object"}
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "family_feature_summary": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "family_id": {"type": "string"},
        "message_count": {"type": "integer", "minimum": 0},
        "length_stats": {"type": "object"},
        "position_stats": {"type": "object"},
        "aggregate_byte_histogram": {"type": "object"},
        "entropy_summary": {"type": "object"},
        "unique_ratio_summary": {"type": "object"},
        "run_length_summary": {"type": "object"},
        "motif_stats": {"type": "object"},
        "structure_stats": {"type": "object"},
        "example_msg_ids": {
          "type": "array",
          "items": {"type": "integer"}
        }
      }
    },
    "family_relation": {
      "type": "object",
      "required": ["request_family_id", "response_family_id", "pair_count", "avg_pair_score"],
      "additionalProperties": false,
      "properties": {
        "request_family_id": {"type": "string"},
        "response_family_id": {"type": "string"},
        "pair_count": {"type": "integer", "minimum": 0},
        "avg_pair_score": {"type": "number"},
        "support_ratio": {"type": "number"},
        "edge_lift": {"type": "number"},
        "direction_consistency": {"type": "number"},
        "dominant_direction": {"type": "string"},
        "temporal_order_consistency": {"type": "number"},
        "order_usable_pairs": {"type": "integer", "minimum": 0},
        "avg_latency_ms": {"type": ["number", "null"]},
        "relation_type": {"type": ["string", "null"]},
        "semantic_label": {"type": ["string", "null"]},
        "confidence": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
        "echo_fields": {
          "type": "array",
          "items": {"type": "object"}
        },
        "length_relations": {
          "type": "array",
          "items": {"type": "object"}
        },
        "attributes": {"type": "object"}
      }
    },
    "family": {
      "type": "object",
      "required": ["family_id", "role", "message_count", "template"],
      "additionalProperties": false,
      "properties": {
        "family_id": {"type": "string"},
        "role": {"type": "string"},
        "message_count": {"type": "integer", "minimum": 0},
        "template": {"type": "string"},
        "segments": {
          "type": "array",
          "items": {"$ref": "#/$defs/segment"}
        },
        "field_hypotheses": {
          "type": "array",
          "items": {"$ref": "#/$defs/field_hypothesis"}
        },
        "feature_summary": {"$ref": "#/$defs/family_feature_summary"},
        "semantic_summary": {"$ref": "#/$defs/family_semantic_summary"},
        "keyword_summary": {
          "type": ["object", "null"],
          "description": "Candidate discriminating keyword bytes and keyword-based subformats from stage 09."
        },
        "framing_summary": {
          "type": ["object", "null"],
          "description": "Protocol-agnostic framing/header layout hypotheses from stage 04."
        },
        "layer_info": {
          "type": ["object", "null"],
          "description": "A6: Multi-layer protocol structure information",
          "properties": {
            "has_layers": {"type": "boolean"},
            "outer_header_end": {"type": "integer", "minimum": 0},
            "inner_payload_start": {"type": "integer", "minimum": 0},
            "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "evidence": {"type": "object"}
          }
        },
        "related_families": {
          "type": "array",
          "items": {"type": "string"}
        },
        "examples": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "evidence": {"type": "object"}
      }
    }
  }
}
