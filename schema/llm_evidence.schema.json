{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/llm_evidence.schema.json",
  "title": "Protocol RE LLM Evidence Bundle",
  "description": "Compact, protocol-agnostic evidence bundle for LLM-assisted industrial protocol reverse engineering. Raw payloads are intentionally omitted; the bundle summarizes inferred families, candidate fields, feature digests, relations, and evaluation quality signals.",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "protocol",
    "source",
    "coverage",
    "llm_guidance",
    "evaluation",
    "relations",
    "global_hypotheses",
    "families",
    "open_questions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this LLM evidence schema."
    },
    "artifact_type": {
      "const": "llm_protocol_evidence_bundle"
    },
    "protocol": {
      "type": "object",
      "required": ["name", "version", "guess"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "guess": {
          "type": "string",
          "description": "Best protocol guess. Keep as 'unknown' unless evidence supports a known protocol."
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["model_metadata", "total_families_in_model", "families_in_bundle", "total_relations_in_model", "relations_in_bundle", "limits"],
      "additionalProperties": false,
      "properties": {
        "model_metadata": {"type": "object"},
        "total_families_in_model": {"type": "integer", "minimum": 0},
        "families_in_bundle": {"type": "integer", "minimum": 0},
        "total_relations_in_model": {"type": "integer", "minimum": 0},
        "relations_in_bundle": {"type": "integer", "minimum": 0},
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "family_limit": {"type": ["integer", "null"], "minimum": 1},
            "field_limit_per_family": {"type": "integer", "minimum": 1},
            "vector_top_offsets": {"type": "integer", "minimum": 1},
            "relation_limit": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["filled_sections", "missing_sections", "completeness_score"],
      "additionalProperties": false,
      "properties": {
        "filled_sections": {"type": "array", "items": {"type": "string"}},
        "missing_sections": {"type": "array", "items": {"type": "string"}},
        "completeness_score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "llm_guidance": {
      "type": "object",
      "required": ["purpose", "recommended_tasks", "raw_payloads_included"],
      "additionalProperties": false,
      "properties": {
        "purpose": {"type": "string"},
        "recommended_tasks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "identify_message_families",
              "name_fields",
              "infer_opcodes",
              "infer_lengths",
              "explain_request_response_relations",
              "flag_low_confidence_hypotheses",
              "suggest_boundary_repairs",
              "identify_constants",
              "semantic_labeling"
            ]
          }
        },
        "raw_payloads_included": {"type": "boolean"}
      }
    },
    "evaluation": {"$ref": "#/$defs/evaluation"},
    "relations": {
      "type": "array",
      "description": "Top global request/response family relation evidence. This avoids repeating large relation arrays inside each family.",
      "items": {"$ref": "#/$defs/relation"}
    },
    "global_hypotheses": {
      "type": "object",
      "required": ["length_candidates", "opcode_candidates", "constants", "low_confidence_areas"],
      "additionalProperties": false,
      "properties": {
        "length_candidates": {"type": "array", "items": {"$ref": "#/$defs/global_field"}},
        "opcode_candidates": {"type": "array", "items": {"$ref": "#/$defs/global_field"}},
        "constants": {"type": "array", "items": {"$ref": "#/$defs/global_field"}},
        "low_confidence_areas": {"type": "array", "items": {"$ref": "#/$defs/global_field"}}
      }
    },
    "families": {
      "type": "array",
      "description": "Compact per-family evidence. Families are ordered by message count unless a family limit is provided.",
      "items": {"$ref": "#/$defs/family"}
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "quantiles": {
      "type": "object",
      "additionalProperties": {"type": ["number", "integer", "null"]},
      "properties": {
        "min": {"type": ["number", "integer"]},
        "p25": {"type": ["number", "integer"]},
        "median": {"type": ["number", "integer"]},
        "p75": {"type": ["number", "integer"]},
        "max": {"type": ["number", "integer"]},
        "mean": {"type": ["number", "integer"]}
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "corpus": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "message_count": {"type": ["integer", "null"], "minimum": 0},
            "session_count": {"type": ["integer", "null"], "minimum": 0},
            "payload_length": {"$ref": "#/$defs/quantiles"},
            "direction_counts": {"type": "object", "additionalProperties": {"type": "integer"}}
          }
        },
        "clustering": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "assignment_coverage_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "family_count": {"type": ["integer", "null"], "minimum": 0},
            "noise_count": {"type": ["integer", "null"], "minimum": 0},
            "cluster_size_distribution": {"$ref": "#/$defs/quantiles"}
          }
        },
        "boundaries": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "parseable_family_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "parseable_family_count": {"type": ["integer", "null"], "minimum": 0},
            "field_confidence_distribution": {"$ref": "#/$defs/quantiles"},
            "segment_confidence_distribution": {"$ref": "#/$defs/quantiles"}
          }
        },
        "pairs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pair_count": {"type": ["integer", "null"], "minimum": 0},
            "score_distribution": {"$ref": "#/$defs/quantiles"},
            "direction_unknown_pair_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
          }
        },
        "relations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "edge_count": {"type": ["integer", "null"], "minimum": 0},
            "avg_pair_score_distribution": {"$ref": "#/$defs/quantiles"},
            "edges_with_echo_fields": {"type": ["integer", "null"], "minimum": 0},
            "edges_with_length_relations": {"type": ["integer", "null"], "minimum": 0},
            "role_hint_counts": {"type": "object", "additionalProperties": {"type": "integer"}}
          }
        },
        "semantics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "semantic_coverage_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "semantic_family_count": {"type": ["integer", "null"], "minimum": 0},
            "role_counts": {"type": "object", "additionalProperties": {"type": "integer"}},
            "top_field_labels": {"type": "array", "items": {"$ref": "#/$defs/counter_item"}}
          }
        }
      }
    },
    "counter_item": {
      "type": "object",
      "required": ["value", "count"],
      "additionalProperties": false,
      "properties": {
        "value": {"type": ["string", "integer", "number"]},
        "count": {"type": "integer", "minimum": 0}
      }
    },
    "template_digest": {
      "type": "object",
      "required": ["byte_length", "prefix", "truncated"],
      "additionalProperties": false,
      "properties": {
        "byte_length": {"type": "integer", "minimum": 0},
        "prefix": {"type": "string"},
        "truncated": {"type": "boolean"}
      }
    },
    "field": {
      "type": "object",
      "required": ["start", "end", "length", "label", "confidence"],
      "additionalProperties": false,
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "length": {"type": "integer", "minimum": 0},
        "label": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "endian": {"type": ["string", "null"]},
        "evidence": {"type": "object"}
      }
    },
    "global_field": {
      "type": "object",
      "required": ["start", "end", "length", "label", "confidence", "family_id"],
      "additionalProperties": false,
      "properties": {
        "family_id": {"type": ["string", "null"]},
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "length": {"type": "integer", "minimum": 0},
        "label": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "endian": {"type": ["string", "null"]},
        "evidence": {"type": "object"},
        "reason": {"type": "string"}
      }
    },
    "segment": {
      "type": "object",
      "required": ["start", "end", "kind", "confidence"],
      "additionalProperties": false,
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "kind": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "vector_digest": {
      "type": "object",
      "required": ["length", "top_offsets"],
      "additionalProperties": false,
      "properties": {
        "length": {"type": "integer", "minimum": 0},
        "top_offsets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["offset", "value"],
            "additionalProperties": false,
            "properties": {
              "offset": {"type": "integer", "minimum": 0},
              "value": {"type": "number"}
            }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "examples": {"type": "array", "items": {"type": "integer"}},
        "length": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {"type": ["integer", "number", "null"]},
            "max": {"type": ["integer", "number", "null"]},
            "mean": {"type": ["integer", "number", "null"]},
            "distinct": {"type": ["integer", "null"], "minimum": 0},
            "top_lengths": {"type": "object", "additionalProperties": {"type": "integer"}}
          }
        },
        "entropy": {"type": "object"},
        "unique_ratio": {"type": "object"},
        "position_vectors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "entropy": {"$ref": "#/$defs/vector_digest"},
            "unique_ratio": {"$ref": "#/$defs/vector_digest"},
            "coverage": {"$ref": "#/$defs/vector_digest"}
          }
        },
        "motifs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repetition_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "top": {"type": "array", "items": {"type": "object"}},
            "wide": {"type": "array", "items": {"type": "object"}}
          }
        },
        "structure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "length_profile": {"type": "object"},
            "trailing_block": {"type": "object"},
            "recurring_groups": {"type": "array", "items": {"type": "object"}}
          }
        }
      }
    },
    "format": {
      "type": "object",
      "required": ["keyword", "keyword_format_count", "best_subcluster_strategy", "scores", "top_formats"],
      "additionalProperties": false,
      "properties": {
        "keyword": {"type": ["object", "null"]},
        "keyword_format_count": {"type": "integer", "minimum": 0},
        "best_subcluster_strategy": {"type": ["string", "null"]},
        "scores": {"type": "object", "additionalProperties": {"type": ["integer", "number"]}},
        "top_formats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["format_id", "message_count", "template"],
            "additionalProperties": false,
            "properties": {
              "format_id": {"type": "string"},
              "message_count": {"type": ["integer", "null"], "minimum": 0},
              "source_subcluster_id": {"type": ["string", "null"]},
              "template": {"$ref": "#/$defs/template_digest"}
            }
          }
        }
      }
    },
    "relation": {
      "type": "object",
      "required": ["request_family_id", "response_family_id", "pair_count", "avg_pair_score"],
      "additionalProperties": false,
      "properties": {
        "request_family_id": {"type": ["string", "null"]},
        "response_family_id": {"type": ["string", "null"]},
        "pair_count": {"type": ["integer", "null"], "minimum": 0},
        "avg_pair_score": {"type": ["number", "null"]},
        "avg_latency_ms": {"type": ["number", "null"]},
        "echo_fields": {"type": "array", "items": {"type": "object"}},
        "length_relations": {"type": "array", "items": {"type": "object"}}
      }
    },
    "family": {
      "type": "object",
      "required": ["family_id", "role", "message_count", "template", "examples", "related_family_ids", "segments", "fields", "semantic_labels", "features", "format", "confidence_notes"],
      "additionalProperties": false,
      "properties": {
        "family_id": {"type": ["string", "null"]},
        "role": {"type": "string", "enum": ["request", "response", "unknown", "mixed"]},
        "message_count": {"type": "integer", "minimum": 0},
        "template": {"$ref": "#/$defs/template_digest"},
        "examples": {"type": "array", "items": {"type": "integer"}},
        "related_family_ids": {"type": "array", "items": {"type": "string"}},
        "segments": {"type": "array", "items": {"$ref": "#/$defs/segment"}},
        "fields": {"type": "array", "items": {"$ref": "#/$defs/field"}},
        "semantic_labels": {"type": "array", "items": {"$ref": "#/$defs/field"}},
        "features": {"$ref": "#/$defs/features"},
        "format": {"$ref": "#/$defs/format"},
        "confidence_notes": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
