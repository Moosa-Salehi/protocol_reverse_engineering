{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/evaluation_output.schema.json",
  "title": "Protocol RE Final Evaluation Report",
  "description": "Report produced by comparing a predicted protocol model/spec against a ground-truth protocol specification.",
  "type": "object",
  "required": ["artifact_type", "protocol_name", "summary", "metrics"],
  "additionalProperties": false,
  "properties": {
    "artifact_type": {"const": "protocol_re_final_evaluation_report"},
    "protocol_name": {"type": "string"},
    "evaluation_timestamp": {"type": "string", "format": "date-time"},
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "predicted_protocol_file": {"type": "string"},
        "ground_truth_protocol_file": {"type": "string"}
      }
    },
    "summary": {
      "type": "object",
      "required": ["overall_score", "verdict"],
      "additionalProperties": true,
      "properties": {
        "overall_score": {"type": "number", "minimum": 0, "maximum": 1},
        "verdict": {"type": "string"},
        "predicted_family_count": {"type": "integer", "minimum": 0},
        "ground_truth_message_type_count": {"type": "integer", "minimum": 0},
        "matched_message_type_count": {"type": "integer", "minimum": 0}
      }
    },
    "metrics": {
      "type": "object",
      "required": ["message_type_matching", "field_boundary", "field_semantics", "relations"],
      "additionalProperties": false,
      "properties": {
        "message_type_matching": {"$ref": "#/$defs/prf_metrics"},
        "field_boundary": {"$ref": "#/$defs/prf_metrics"},
        "field_semantics": {"$ref": "#/$defs/prf_metrics"},
        "relations": {"$ref": "#/$defs/prf_metrics"}
      }
    },
    "matches": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "message_types": {
          "type": "array",
          "items": {"$ref": "#/$defs/message_type_match"}
        },
        "fields": {
          "type": "array",
          "items": {"$ref": "#/$defs/field_match"}
        },
        "relations": {
          "type": "array",
          "items": {"$ref": "#/$defs/relation_match"}
        }
      }
    },
    "unmatched": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "predicted_families": {"type": "array", "items": {"type": "string"}},
        "ground_truth_message_types": {"type": "array", "items": {"type": "string"}},
        "predicted_fields": {"type": "array", "items": {"$ref": "#/$defs/field_ref"}},
        "ground_truth_fields": {"type": "array", "items": {"$ref": "#/$defs/field_ref"}}
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "prf_metrics": {
      "type": "object",
      "required": ["true_positives", "false_positives", "false_negatives", "accuracy", "precision", "recall", "f1_score"],
      "additionalProperties": true,
      "properties": {
        "true_positives": {"type": "integer", "minimum": 0},
        "false_positives": {"type": "integer", "minimum": 0},
        "false_negatives": {"type": "integer", "minimum": 0},
        "accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "precision": {"type": "number", "minimum": 0, "maximum": 1},
        "recall": {"type": "number", "minimum": 0, "maximum": 1},
        "f1_score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "message_type_match": {
      "type": "object",
      "required": ["predicted_family_id", "ground_truth_message_type_id", "score"],
      "additionalProperties": true,
      "properties": {
        "predicted_family_id": {"type": "string"},
        "ground_truth_message_type_id": {"type": "string"},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": "string"}
      }
    },
    "field_ref": {
      "type": "object",
      "required": ["owner_id", "field_name"],
      "additionalProperties": true,
      "properties": {
        "owner_id": {"type": "string"},
        "field_name": {"type": "string"},
        "start": {"type": "integer", "minimum": 0},
        "length": {"type": ["integer", "null"], "minimum": 1},
        "field_type": {"type": "string"}
      }
    },
    "field_match": {
      "type": "object",
      "required": ["predicted", "ground_truth", "boundary_score", "semantic_score"],
      "additionalProperties": true,
      "properties": {
        "predicted": {"$ref": "#/$defs/field_ref"},
        "ground_truth": {"$ref": "#/$defs/field_ref"},
        "boundary_score": {"type": "number", "minimum": 0, "maximum": 1},
        "semantic_score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "relation_match": {
      "type": "object",
      "required": ["predicted_request_family_id", "predicted_response_family_id", "ground_truth_request_message_type_id", "ground_truth_response_message_type_id", "score"],
      "additionalProperties": true,
      "properties": {
        "predicted_request_family_id": {"type": "string"},
        "predicted_response_family_id": {"type": "string"},
        "ground_truth_request_message_type_id": {"type": "string"},
        "ground_truth_response_message_type_id": {"type": "string"},
        "score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
