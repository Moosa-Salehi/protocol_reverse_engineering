{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/evaluation_input.schema.json",
  "title": "Protocol RE Final Evaluation Input",
  "description": "Input bundle for comparing the pipeline protocol model/spec against a ground-truth protocol specification.",
  "type": "object",
  "required": ["predicted_protocol", "ground_truth_protocol"],
  "additionalProperties": false,
  "properties": {
    "predicted_protocol": {"$ref": "#/$defs/predicted_protocol"},
    "ground_truth_protocol": {"$ref": "#/$defs/ground_truth_protocol"},
    "metadata": {"type": "object"}
  },
  "$defs": {
    "predicted_protocol": {
      "type": "object",
      "required": ["protocol_name", "families"],
      "additionalProperties": true,
      "properties": {
        "protocol_name": {"type": "string"},
        "version": {"type": "string"},
        "metadata": {"type": "object"},
        "families": {
          "type": "array",
          "items": {"$ref": "#/$defs/predicted_family"}
        },
        "relations": {
          "type": "array",
          "items": {"$ref": "#/$defs/predicted_relation"}
        },
        "llm_analysis": {"type": ["object", "string", "null"]}
      }
    },
    "ground_truth_protocol": {
      "type": "object",
      "required": ["protocol_name", "message_types"],
      "additionalProperties": true,
      "properties": {
        "protocol_name": {"type": "string"},
        "version": {"type": "string"},
        "description": {"type": "string"},
        "message_types": {
          "type": "array",
          "items": {"$ref": "#/$defs/ground_truth_message_type"}
        },
        "relations": {
          "type": "array",
          "items": {"$ref": "#/$defs/ground_truth_relation"}
        }
      }
    },
    "predicted_family": {
      "type": "object",
      "required": ["family_id"],
      "additionalProperties": true,
      "properties": {
        "family_id": {"type": "string"},
        "role": {"type": "string"},
        "message_count": {"type": "integer", "minimum": 0},
        "template": {"type": "string"},
        "segments": {
          "type": "array",
          "items": {"$ref": "#/$defs/segment"}
        },
        "field_hypotheses": {
          "type": "array",
          "items": {"$ref": "#/$defs/predicted_field"}
        },
        "semantic_summary": {"type": ["object", "null"]},
        "evidence": {"type": "object"}
      }
    },
    "ground_truth_message_type": {
      "type": "object",
      "required": ["message_type_id", "fields"],
      "additionalProperties": true,
      "properties": {
        "message_type_id": {"type": "string"},
        "name": {"type": "string"},
        "role": {"type": "string"},
        "description": {"type": "string"},
        "fields": {
          "type": "array",
          "items": {"$ref": "#/$defs/ground_truth_field"}
        },
        "examples": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "segment": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": true,
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "kind": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "predicted_field": {
      "type": "object",
      "required": ["start", "length", "field_type"],
      "additionalProperties": true,
      "properties": {
        "family_id": {"type": "string"},
        "start": {"type": "integer", "minimum": 0},
        "length": {"type": "integer", "minimum": 1},
        "field_type": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "endian": {"type": ["string", "null"]},
        "evidence": {"type": "object"},
        "attributes": {"type": "object"}
      }
    },
    "ground_truth_field": {
      "type": "object",
      "required": ["name", "start", "length", "field_type"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string"},
        "start": {"type": "integer", "minimum": 0},
        "length": {"type": ["integer", "null"], "minimum": 1},
        "end": {"type": ["integer", "null"], "minimum": 0},
        "field_type": {"type": "string"},
        "required": {"type": "boolean"},
        "constant_value": {"type": ["string", "number", "integer", "null"]},
        "endian": {"type": ["string", "null"]},
        "description": {"type": "string"}
      }
    },
    "predicted_relation": {
      "type": "object",
      "required": ["request_family_id", "response_family_id"],
      "additionalProperties": true,
      "properties": {
        "request_family_id": {"type": "string"},
        "response_family_id": {"type": "string"},
        "pair_count": {"type": "integer", "minimum": 0},
        "avg_pair_score": {"type": "number"}
      }
    },
    "ground_truth_relation": {
      "type": "object",
      "required": ["request_message_type_id", "response_message_type_id"],
      "additionalProperties": true,
      "properties": {
        "request_message_type_id": {"type": "string"},
        "response_message_type_id": {"type": "string"},
        "relation_type": {"type": "string"},
        "description": {"type": "string"}
      }
    }
  }
}
